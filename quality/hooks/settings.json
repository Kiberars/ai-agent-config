{
  "hooks": [
    {
      "type": "PreToolUse",
      "description": "Block destructive operations without explicit user confirmation",
      "matcher": {
        "tool_name": "bash"
      },
      "rules": [
        {
          "name": "block_destructive_bash",
          "description": "Intercept dangerous shell commands",
          "patterns": [
            "rm\\s+-rf",
            "DROP\\s+(TABLE|DATABASE|SCHEMA)",
            "TRUNCATE\\s+TABLE",
            "DELETE\\s+FROM\\s+\\w+\\s*;",
            "git\\s+push\\s+.*--force",
            "git\\s+reset\\s+--hard",
            "> /dev/null",
            "chmod\\s+777",
            "sudo\\s+rm",
            "pkill\\s+-9",
            ":(){:|:&};:"
          ],
          "action": "pause",
          "message": "⚠️  Potentially destructive command detected:\n\n  {command}\n\nConfirm you want to run this? (yes / no)"
        }
      ]
    },
    {
      "type": "PreToolUse",
      "description": "Warn before writing to production config files",
      "matcher": {
        "tool_name": "write_file"
      },
      "rules": [
        {
          "name": "protect_prod_configs",
          "description": "Ask before touching sensitive files",
          "patterns": [
            "\\.env\\.prod",
            "\\.env\\.production",
            "production\\.ya?ml",
            "prod\\.config\\.",
            "secrets\\.",
            "\\.pem$",
            "\\.key$"
          ],
          "action": "pause",
          "message": "⚠️  About to write to a production/secrets file:\n\n  {path}\n\nConfirm? (yes / no)"
        }
      ]
    },
    {
      "type": "PostToolUse",
      "description": "Auto-format files after edit",
      "matcher": {
        "tool_name": "write_file"
      },
      "command": "pre-commit run --files {file_path} 2>/dev/null || true",
      "timeout_ms": 10000
    },
    {
      "type": "Stop",
      "description": "Run tests after every task completion",
      "command": "npm test --passWithNoTests 2>/dev/null || python -m pytest -q 2>/dev/null || echo 'No test runner detected'",
      "timeout_ms": 60000,
      "on_failure": "warn"
    },
    {
      "type": "Stop",
      "description": "Remind agent to update CHANGELOG",
      "check": "git diff --name-only HEAD | grep -q CHANGELOG.md || echo 'REMINDER: Update CHANGELOG.md before closing the task.'",
      "timeout_ms": 5000,
      "on_failure": "warn"
    }
  ]
}
